# MeX Next environment variables
# Doppler が source of truth、これは bootstrap 時の hint のみ

# Doppler service token (read-only, scoped to project xops-<account-id>/prd)
DOPPLER_TOKEN=

# Discord bot token (or fetched from Doppler at runtime)
DISCORD_BOT_TOKEN=

# Anthropic API key (for intent classify / risk classify)
ANTHROPIC_API_KEY=

# X (Twitter) API v2 credentials
X_API_CONSUMER_KEY=
X_API_CONSUMER_SECRET=
X_API_ACCESS_TOKEN=
X_API_ACCESS_TOKEN_SECRET=

# Account scope
ACCOUNT_ID=
ACCOUNT_REPO=/srv/mex/<account-id>-x-ops

# Operator allowlist (comma-separated Discord user IDs)
OPERATOR_DISCORD_USER_IDS=

# Optional: GitHub token for self-update gh access
GITHUB_TOKEN=

# Logger level (trace|debug|info|warn|error)
LOG_LEVEL=info
