{
  "name": "mex-next",
  "version": "0.1.0",
  "description": "MeX Next — X (Twitter) account operation OS, rebuilt on Node.js + TypeScript with conversational Discord UX",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "watch": "tsc -p tsconfig.json --watch",
    "start": "node dist/main.js",
    "dev": "tsx src/main.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint 'src/**/*.ts'",
    "lint:fix": "eslint --fix 'src/**/*.ts'",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts' 'docs/**/*.md'",
    "format:check": "prettier --check 'src/**/*.ts' 'tests/**/*.ts'",
    "prepare": "husky install"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "tests/**/*.ts": [
      "prettier --write"
    ],
    "*.{md,json,yml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "discord.js": "^14.16.0",
    "execa": "^9.5.0",
    "pino": "^9.5.0",
    "proper-lockfile": "^4.1.2",
    "twitter-api-v2": "^1.18.0",
    "ulid": "^2.3.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/proper-lockfile": "^4.1.4",
    "eslint": "^9.39.4",
    "husky": "^9.1.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.3.3",
    "tsx": "^4.19.0",
    "typescript-eslint": "^8.59.1",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
