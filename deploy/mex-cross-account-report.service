[Unit]
Description=MeX Next cross-account report (operator)
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
Environment=HOME=/root
EnvironmentFile=/etc/mex/operator.env
WorkingDirectory=/opt/mex-next
ExecStart=/usr/bin/node /opt/mex-next/dist/scripts/cross-account-report.js --registry-path /var/lib/mex-next/accounts-registry.json
StandardOutput=journal
StandardError=journal
