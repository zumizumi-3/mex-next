[Unit]
Description=MeX Next weekly retrospective ({ACCOUNT_ID})
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
Environment=HOME=/root
EnvironmentFile=/etc/mex/{ACCOUNT_ID}.env
WorkingDirectory=/opt/mex-next
ExecStart=/usr/bin/doppler run --project xops-{ACCOUNT_ID} --config prd -- /usr/bin/node /opt/mex-next/dist/scripts/cron-periodic-retro.js --account-id {ACCOUNT_ID} --horizon weekly
StandardOutput=journal
StandardError=journal
